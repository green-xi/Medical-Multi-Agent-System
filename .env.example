# ══════════════════════════════════════════════════════════════
# MedicalAI 环境变量配置 — 复制为 .env 并填入真实 Key
# ══════════════════════════════════════════════════════════════

# ── LLM API（必填）────────────────────────────────────────────
# 阿里云 DashScope（通义千问）API Key
# 申请地址：https://dashscope.aliyun.com/
DASHSCOPE_API_KEY=your_dashscope_api_key_here

# ── 联网搜索（可选）────────────────────────────────────────────
# Tavily 搜索 API Key，不填则跳过联网搜索
# 申请地址：https://tavily.com/
TAVILY_API_KEY=your_tavily_api_key_here

# ── MCP 外部工具（可选）─────────────────────────────────────────
# 使用 MCP 协议接入 Wikipedia / PubMed / Tavily 等工具
# 设为 false 则回退到 langchain 原生实现
MCP_ENABLED=true

# ── 嵌入模型路径（可选，留空则自动探测）────────────────────────
EMBEDDING_MODEL=

# ── Reranker 模型路径（可选，留空则自动探测）───────────────────
RERANKER_MODEL=
